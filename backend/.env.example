# ==============================================================================
# ESSENTIAL API KEYS & CONFIGURATIONS
# ==============================================================================
DATABASE_URL=sqlite:///./test.db
SECRET_KEY=your_secret_key_here
FRONTEND_URL=http://localhost:3009

# ==============================================================================
# OPTIONAL API KEYS
# ==============================================================================
# 1. Google Gemini API Key (Used for Quizzes & AI Generation features)
# Get it here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# 2. HuggingFace API Key (Used for Note Summarization)
# Get it here: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# 3. Google Vision API Key (Used for OCR / Extracting text from images)
# Get it here: https://console.cloud.google.com/apis/library/vision.googleapis.com
GOOGLE_VISION_API_KEY=

# 4. Firebase Keys (Only needed if enforcing Firebase Auth in backend)
# Get it from Firebase Console -> Project Settings -> General
FIREBASE_API_KEY=
FIREBASE_PROJECT_ID=
